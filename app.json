{
  "expo": {
    "name": "SmartReceipt",
    "slug": "SmartReceipt",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "smartreceipt",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.smartreceipt.ge"
    },
    "android": {
      "package": "com.smartreceipt.ge",
      "versionCode": 4,
      "adaptiveIcon": {
        "backgroundColor": "#18182B",
        "foregroundImage": "./assets/images/icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#18182B",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 200
          }
        }
      ],
      "expo-sqlite",
      "expo-sharing",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8653699399884825~1909751141",
          "iosAppId": "ca-app-pub-8653699399884825~1909751141"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8142414b-1a14-49ca-be53-3a6d5bf4a22b"
      }
    }
  }
}
